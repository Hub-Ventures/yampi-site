---
// Home del sitio comercial Yampi.
// Cambia HERO_VARIANT a 'claro' | 'oscuro' | 'split' para usar otra variante de hero.
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroClaro from '../components/heroes/HeroClaro.astro';
import HeroOscuro from '../components/heroes/HeroOscuro.astro';
import HeroSplit from '../components/heroes/HeroSplit.astro';
import CtaFinal from '../components/CtaFinal.astro';
import ShotPlaceholder from '../components/ShotPlaceholder.astro';
import Icon from '../components/Icon.astro';
import data from '../data/modules.json';
import { CAT_ORDER, CAT_COLOR, groupByCat } from '../lib/categories.js';

const HERO_VARIANT = 'claro';
const MOSTRAR_LOGOS = true;

const byCat = groupByCat(data);

const capacidades = [
  {
    num: '01',
    cat: 'atiende',
    title: 'Atiende cada lead en segundos, en cualquier canal',
    text: 'WhatsApp, Instagram, TikTok, email y llamadas en una sola bandeja. Livia, tu asistente IA, califica leads, envía fotos de propiedades y agenda visitas mientras tu equipo duerme.',
    label: 'Screenshot: bandeja omnicanal con Livia',
    flip: false,
  },
  {
    num: '02',
    cat: 'vende',
    title: 'Convierte tu inventario en negocios cerrados',
    text: 'Propiedades conectadas al pipeline, visitas que el cliente agenda solo y un perfil público que convierte a cada asesor en una landing de captación. Del primer mensaje a la firma, sin perder el contexto.',
    label: 'Screenshot: pipeline de oportunidades',
    flip: true,
  },
  {
    num: '03',
    cat: 'cobra',
    title: 'Firma contratos en horas y cobra sin perseguir a nadie',
    text: 'Firma electrónica con OTP por WhatsApp, contratos que activan la suscripción de cobro automáticamente, pasarelas colombianas con PSE y desembolsos a propietarios sin conciliación manual.',
    label: 'Screenshot: dashboard de tesorería',
    flip: false,
  },
  {
    num: '04',
    cat: 'automatiza',
    title: 'Escala tu operación sin contratar más gente',
    text: 'Automatizaciones por eventos, campañas masivas de WhatsApp, reportes en tiempo real y permisos a la medida. La operación crece; el caos no.',
    label: 'Screenshot: editor de automatizaciones',
    flip: true,
  },
];
---
<BaseLayout
  title="Yampi — La plataforma para operar toda tu inmobiliaria"
  description="Comunicaciones omnicanal, propiedades, contratos con firma electrónica, cobro de arriendos e IA inmobiliaria en una sola plataforma. La alternativa todo-en-uno a tu CRM, tu firma y tu pasarela de cobros, hecha para Latinoamérica."
>
  {HERO_VARIANT === 'claro' && <HeroClaro />}
  {HERO_VARIANT === 'oscuro' && <HeroOscuro />}
  {HERO_VARIANT === 'split' && <HeroSplit />}

  {MOSTRAR_LOGOS && (
    <section class="logos-band" data-screen-label="Franja de logos">
      <div class="wrap">
        <p>Equipos inmobiliarios que operan con Yampi</p>
        <div class="logos-row">
          {[1, 2, 3, 4, 5].map(() => <div class="logo-ph">Logo cliente</div>)}
        </div>
      </div>
    </section>
  )}

  <section class="section" id="ciclo" data-screen-label="El ciclo completo">
    <div class="wrap">
      <span class="kicker reveal">Una sola plataforma</span>
      <h2 class="display-lg reveal" style="margin-top: 14px;">Todo el ciclo inmobiliario,<br />conectado de punta a punta</h2>
      <p class="lede reveal" style="max-width: 700px; margin-top: 18px;">Cada etapa alimenta la siguiente sin exportar datos ni cambiar de herramienta: el lead que entra por WhatsApp termina como un arriendo que se cobra y se desembolsa solo.</p>
      <div class="cycle reveal">
        <div class="cycle-line"></div>
        <div class="cycle-step">
          <div class="cycle-node" style="background: var(--blue-3); color: var(--blue-11);"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg></div>
          <span class="cycle-num">01</span>
          <h4>Captación</h4>
          <p>Leads de WhatsApp, Instagram y web a un solo pipeline.</p>
        </div>
        <div class="cycle-step">
          <div class="cycle-node" style="background: var(--iris-3); color: var(--iris-11);"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" /><path d="M9 22v-4h6v4" /><path d="M8 6h.01M16 6h.01M8 10h.01M16 10h.01" /></svg></div>
          <span class="cycle-num">02</span>
          <h4>Propiedades</h4>
          <p>Inventario y disponibilidad enlazados al negocio.</p>
        </div>
        <div class="cycle-step">
          <div class="cycle-node" style="background: var(--yampi-2); color: var(--yampi-11);"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><path d="m9 15 2 2 4-4" /></svg></div>
          <span class="cycle-num">03</span>
          <h4>Contratos</h4>
          <p>Firma electrónica que activa el cobro al cerrar.</p>
        </div>
        <div class="cycle-step">
          <div class="cycle-node" style="background: var(--amber-3); color: var(--amber-11);"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="15.5" r="5.5" /><path d="m21 2-9.6 9.6" /><path d="m15.5 7.5 3 3L22 7l-3-3" /></svg></div>
          <span class="cycle-num">04</span>
          <h4>Arriendo</h4>
          <p>Tenencia activa, con agenda y seguimiento integrados.</p>
        </div>
        <div class="cycle-step">
          <div class="cycle-node" style="background: var(--teal-3); color: var(--teal-11);"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg></div>
          <span class="cycle-num">05</span>
          <h4>Cobros</h4>
          <p>Recaudo recurrente, conciliación y desembolso al dueño.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="modulos" data-screen-label="Módulos por categoría">
    <div class="wrap">
      <h2 class="display-lg reveal">Empieza por un módulo,<br />o úsalo todo en conjunto.</h2>
      <p class="lede reveal" style="max-width: 720px; margin-top: 20px;">Dieciséis módulos que cubren el ciclo inmobiliario completo —atención, ventas, contratos, cobros y automatización—. Juntos reemplazan tu CRM, tu bandeja de WhatsApp, tu firma electrónica, tu pasarela de cobros y las hojas de cálculo, sin integraciones frágiles entre ellos.</p>
      <div class="cat-grid">
        {CAT_ORDER.map((c, i) => (
          <div class="card cat-card reveal">
            <span class="num">{`0${i + 1}`}</span>
            <h3>{data.categories[c].label}</h3>
            <div class="cat-accent" style={`background: ${CAT_COLOR[c]}`}></div>
            <p class="tagline">{data.categories[c].tagline}</p>
            <ul>
              {byCat[c].map((m) => (
                <li>
                  <a href={`/modulos/${m.slug}/`}>
                    <span>{m.name}</span>
                    <Icon name="arrow-right" size={14} />
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="capacidades" style="background: var(--bg-card); border-top: 1px solid var(--border-weak); border-bottom: 1px solid var(--border-weak);" data-screen-label="Capacidades">
    <div class="wrap">
      <span class="kicker reveal">Capacidades</span>
      <h2 class="display-lg reveal" style="margin-top: 14px; margin-bottom: 8px;">Todo lo que Yampi hace<br />por tu inmobiliaria</h2>
      <p class="lede reveal" style="max-width: 680px; margin-bottom: 8px;">Cuatro frentes que cubren el ciclo de punta a punta: desde el primer “hola” por WhatsApp hasta el desembolso al propietario.</p>

      {capacidades.map((cap) => (
        <div class={`cap-block reveal${cap.flip ? ' flip' : ''}`}>
          <div class="cap-copy">
            <span class="num">{cap.num}</span>
            <h3>{cap.title}</h3>
            <p>{cap.text}</p>
            <div class="cap-links">
              {byCat[cap.cat].map((m) => (
                <a href={`/modulos/${m.slug}/`}>
                  <Icon name="arrow-right" size={14} />
                  <span>{m.name}</span>
                </a>
              ))}
            </div>
          </div>
          <ShotPlaceholder height={400} label={cap.label} />
        </div>
      ))}
    </div>
  </section>

  <section class="section section-tint" id="reemplazas" data-screen-label="Lo que reemplazas">
    <div class="wrap">
      <div style="text-align: center; max-width: 720px; margin: 0 auto;">
        <span class="kicker reveal">Consolidación</span>
        <h2 class="display-lg reveal" style="margin-top: 14px;">Una plataforma en vez de<br />seis herramientas sueltas</h2>
        <p class="lede reveal" style="margin-top: 18px;">Cada herramienta que conectas a mano es un punto de fuga: datos que no cuadran, leads que se enfrían y horas de copiar y pegar. Yampi reúne toda la operación en una sola cuenta.</p>
      </div>
      <div class="swap reveal">
        <div class="swap-col swap-old">
          <span class="swap-tag">Tu stack hoy</span>
          <ul>
            <li><span class="ic"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg></span>CRM genérico</li>
            <li><span class="ic"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg></span>Bandeja de WhatsApp por separado</li>
            <li><span class="ic"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg></span>Excel de cobros y cartera</li>
            <li><span class="ic"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg></span>Firma de contratos por correo</li>
            <li><span class="ic"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg></span>Pasarela de pagos aparte</li>
            <li><span class="ic"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg></span>Hoja de propiedades y portales</li>
          </ul>
        </div>
        <div class="swap-arrow"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" /></svg></div>
        <div class="swap-col swap-new">
          <span class="swap-tag swap-tag-brand">Con Yampi</span>
          <ul>
            <li><span class="ic"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg></span>Comunicación omnicanal con IA</li>
            <li><span class="ic"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg></span>Contactos, propiedades y pipeline</li>
            <li><span class="ic"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg></span>Contratos con firma electrónica</li>
            <li><span class="ic"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg></span>Tesorería: cobros y desembolsos</li>
            <li><span class="ic"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg></span>Automatizaciones y reportes</li>
            <li><span class="ic"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg></span>Una sola cuenta, sin integraciones</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <CtaFinal title="Mira Yampi funcionando con tus propias propiedades." />
</BaseLayout>
