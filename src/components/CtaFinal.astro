---
// Sección CTA final oscura, reutilizada en home y páginas de módulo.
import Button from './Button.astro';

const {
  title = 'Mira Yampi funcionando con tus propias propiedades.',
  text = 'Agenda 30 minutos con nuestro equipo. Te mostramos la plataforma con casos reales de inmobiliarias como la tuya — sin compromiso.',
  bordered = false,
} = Astro.props;
---
<section
  class="section-dark cta-final"
  id="demo"
  style={bordered ? 'border-top: 1px solid rgba(255,255,255,0.1);' : undefined}
>
  <div class="wrap">
    <h2 class="display-lg reveal" style="color: var(--fg-on-dark);">{title}</h2>
    <p class="lede reveal">{text}</p>
    <div class="hero-actions reveal">
      <Button action="demo" variant="on-dark" />
    </div>
  </div>
</section>
