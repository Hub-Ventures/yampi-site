  coins: '<circle cx="9" cy="9" r="6"/><path d="M14.2 4.5a6 6 0 1 1-4.7 10.7"/><path d="M9 6.5v5M7 9h4"/>',
  sparkle: '<path d="M12 3l1.9 5.6L19.5 10l-5.6 1.9L12 17.5l-1.9-5.6L4.5 10l5.6-1.4z"/><path d="M19 16v4M17 18h4"/>',
