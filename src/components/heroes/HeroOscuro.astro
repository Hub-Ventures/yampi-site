---
// Hero B — fondo oscuro (charcoal del design system) con mockup que se asoma.
import ShotPlaceholder from '../ShotPlaceholder.astro';
const { src } = Astro.props;
---
<section data-screen-label="Hero oscuro">
  <div class="hero-oscuro">
    <div class="wrap">
      <span class="chip" style="background: rgba(155,81,224,0.18); color: var(--yampi-4);">CRM inteligente para inmobiliarias</span>
      <h1 class="display-xl" style="margin-top: 22px;">Tu inmobiliaria completa,<br />en una sola plataforma.</h1>
      <p class="lede">Comunicaciones, propiedades, contratos, cobros e inteligencia artificial — sin integraciones frágiles ni hojas de cálculo. Construido para Latinoamérica.</p>
      <div class="hero-actions">
        <a class="btn btn-primary btn-lg" href="#demo">Agenda una demo</a>
        <a class="btn btn-ghost-dark btn-lg" href="#modulos">Conoce los módulos</a>
      </div>
      <div class="hero-shot">
        <ShotPlaceholder src={src} height={540} label="Screenshot: panel de control de Yampi" alt="Panel de control de Yampi" />
      </div>
    </div>
  </div>
  <div class="hero-oscuro-spacer"></div>
</section>
