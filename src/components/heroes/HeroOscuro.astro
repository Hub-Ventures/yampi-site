---
// Hero B — fondo oscuro (charcoal del design system) con mockup que se asoma.
import ShotPlaceholder from '../ShotPlaceholder.astro';
import Button from '../Button.astro';

const { src } = Astro.props;
---
<section data-screen-label="Hero oscuro">
  <div class="hero-oscuro">
    <div class="wrap">
      <span class="chip" style="background: rgba(155,81,224,0.18); color: var(--yampi-4);">Plataforma de operaciones inmobiliarias</span>
      <h1 class="display-xl" style="margin-top: 22px;">Tu inmobiliaria completa,<br />en una sola plataforma.</h1>
      <p class="lede">Comunicaciones, propiedades, contratos, cobros e inteligencia artificial en una sola plataforma — no un CRM más, ni integraciones frágiles, ni hojas de cálculo. Construido para Latinoamérica.</p>
      <div class="hero-actions">
        <Button action="demo" />
        <Button variant="ghost-dark" href="#modulos">Conoce los módulos</Button>
      </div>
      <div class="hero-shot">
        <ShotPlaceholder src={src} height={540} label="Screenshot: panel de control de Yampi" alt="Panel de control de Yampi" />
      </div>
    </div>
  </div>
  <div class="hero-oscuro-spacer"></div>
</section>
