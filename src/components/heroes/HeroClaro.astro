---
// Hero A — claro, centrado, con mockup grande debajo (variante elegida).
import ShotPlaceholder from '../ShotPlaceholder.astro';
const { src } = Astro.props;
---
<section data-screen-label="Hero claro">
  <div class="hero-claro wrap">
    <span class="chip">Plataforma de operaciones inmobiliarias</span>
    <h1 class="display-xl" style="margin-top: 22px;">Del primer mensaje<br />al arriendo cobrado.</h1>
    <p class="lede">Yampi conecta atención, ventas, contratos y cobros en una sola plataforma: WhatsApp e IA que califican leads, propiedades enlazadas al pipeline, firma electrónica que activa el cobro y tesorería que recauda y desembolsa sola. Una operación completa en vez de seis herramientas sueltas.</p>
    <div class="hero-actions">
      <a class="btn btn-primary btn-lg" href="#demo">Agenda una demo</a>
      <a class="btn btn-outline btn-lg" href="#modulos">Conoce los módulos</a>
    </div>
  </div>
  <div class="hero-shot">
    <ShotPlaceholder src={src} height={560} label="Screenshot: panel de control de Yampi" alt="Panel de control de Yampi" />
  </div>
</section>
