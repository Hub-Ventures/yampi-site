---
// Hero A — claro, centrado, con mockup grande debajo (variante elegida).
import ShotPlaceholder from '../ShotPlaceholder.astro';
import Button from '../Button.astro';
import { HOME_HERO_TITLE, HOME_HERO_DESCRIPTION, getGoogleSignupUrl } from '../../lib/site-copy.js';

const { src, title = HOME_HERO_TITLE, description = HOME_HERO_DESCRIPTION } = Astro.props;
const googleSignupUrl = getGoogleSignupUrl();
---
<section class="hero-claro" data-screen-label="Hero claro">
  <div class="hero-claro-inner">
    <div class="hero-claro-copy">
      <h1 class="display-xl">{title}</h1>
      <p class="lede">{description}</p>
    </div>
    <div class="hero-actions">
      <Button variant="google" href={googleSignupUrl} label="Comenzar con Google" />
      <Button action="demo" />
    </div>
  </div>
  <div class="hero-shot">
    <ShotPlaceholder src={src} height={560} label="Screenshot: panel de control de Yampi" alt="Panel de control de Yampi" />
  </div>
</section>
