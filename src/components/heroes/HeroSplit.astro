---
// Hero C — split: texto a la izquierda, mockup a la derecha, fondo lila suave.
import ShotPlaceholder from '../ShotPlaceholder.astro';
import Button from '../Button.astro';

const { src } = Astro.props;
---
<section data-screen-label="Hero split">
  <div class="hero-split">
    <div class="wrap grid">
      <div>
        <span class="chip" style="background: var(--bg-card);">Plataforma de operaciones inmobiliarias</span>
        <h1 class="display-lg" style="margin-top: 20px;">Deja de perseguir leads. Empieza a cerrarlos.</h1>
        <p class="lede">Cada mensaje, propiedad, contrato y pago de tu operación inmobiliaria — conectados en una sola plataforma con IA que atiende por ti las 24 horas.</p>
        <div class="hero-actions">
          <Button action="demo" />
          <Button variant="outline" class="btn-on-card" href="#modulos">Conoce los módulos</Button>
        </div>
      </div>
      <ShotPlaceholder src={src} height={460} label="Screenshot: bandeja omnicanal" alt="Bandeja omnicanal de Yampi" />
    </div>
  </div>
</section>
