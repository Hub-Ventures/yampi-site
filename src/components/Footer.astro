---
// Footer oscuro con columnas de módulos por categoría.
import data from '../data/modules.json';
import { CAT_ORDER, groupByCat } from '../lib/categories.js';

const byCat = groupByCat(data);
---
<footer class="footer">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <span class="wordmark">yampi</span>
        <p style="margin-top: 14px; max-width: 260px;">La plataforma todo-en-uno para operar tu inmobiliaria de punta a punta en Latinoamérica.</p>
      </div>
      {CAT_ORDER.map((c) => (
        <div>
          <h5>{data.categories[c].label}</h5>
          {byCat[c].map((m) => (
            <a href={`/modulos/${m.slug}/`} style="display: block;">{m.name}</a>
          ))}
        </div>
      ))}
    </div>
    <div class="footer-bottom">
      <span>© 2026 Yampi. Todos los derechos reservados.</span>
      <span>Hecho para el sector inmobiliario latinoamericano</span>
    </div>
  </div>
</footer>
